meta {
  name: Change Password User A
  type: http
  seq: 6
  tags: [
    auth
  ]
}

patch {
  url: {{auth_base}}/auth/password
}

headers {
  content-type: application/json
  Authorization: Bearer {{access_token}}
}

body {
  {
    "currentPassword": "{{user_a_password}}",
    "newPassword": "{{user_a_new_password}}"
  }
}
