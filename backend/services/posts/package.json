{
  "name": "@transcendence/posts",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/http/server.ts",
    "start": "./server",
    "build": "bun build --compile --external pg --minify-whitespace --minify-syntax --target bun --outfile server src/http/server.ts",
    "test": "bun test --env-file .env.test",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@elysiajs/bearer": "1.4.3",
    "@elysiajs/cors": "1.4.1",
    "@elysiajs/eden": "1.4.8",
    "@elysiajs/jwt": "1.4.1",
    "@elysiajs/openapi": "1.4.14",
    "@elysiajs/opentelemetry": "1.4.10",
    "@opentelemetry/exporter-trace-otlp-proto": "0.214.0",
    "@opentelemetry/instrumentation-pg": "0.66.0",
    "@opentelemetry/sdk-trace-node": "2.6.1",
    "drizzle-orm": "0.45.1",
    "elysia": "1.4.28",
    "pg": "8.20.0",
    "uuidv7": "1.2.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "@types/bun": "1.3.11",
    "@types/pg": "8.20.0",
    "drizzle-kit": "0.31.10",
    "drizzle-zod": "0.8.3",
    "ultracite": "7.3.2"
  },
  "peerDependencies": {
    "typescript": "5"
  }
}
