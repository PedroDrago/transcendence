meta {
  name: Login User A After Password Change
  type: http
  seq: 8
  tags: [
    auth
  ]
}

post {
  url: {{auth_base}}/auth/login
}

headers {
  content-type: application/json
}

body {
  {
    "identifier": "{{user_a_email}}",
    "password": "{{user_a_new_password}}"
  }
}

script:post-response {
  if (res.status === 200 && res.body && res.body.access_token) {
    bru.setEnvVar("access_token", res.body.access_token);
  }
}
